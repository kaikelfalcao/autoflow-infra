# Credenciais do ecossistema autoflow. Copie para `.env` (gitignored).

# New Relic — license/ingest, user API key, account ID, região (US ou EU).
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_API_KEY=
NEW_RELIC_ACCOUNT_ID=
NEW_RELIC_REGION=US

# Mercado Pago — vazio em dev (mock); preencha em prod.
MP_ACCESS_TOKEN=

# AWS Academy Learner Lab — copie do painel após iniciar a sessão (AWS Details).
# Expiram em ~4h; rotacione sempre que iniciar nova sessão.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1

# DockerHub — usado para push das 6 imagens.
DOCKER_USERNAME=
DOCKER_PASSWORD=
