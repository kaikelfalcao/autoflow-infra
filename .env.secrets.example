# Template para sync-github-secrets.sh
# Copie para .env (ou outro path) e preencha os valores reais.
# NUNCA commitar o arquivo com valores reais.

# DockerHub (para os pipelines fazerem push das imagens)
DOCKER_USERNAME=
DOCKER_PASSWORD=

# AWS Lab (credenciais temporárias — expiram a cada sessão do AWS Academy)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# New Relic (license key para o agente nos pods)
NEW_RELIC_LICENSE_KEY=
