{
  "name": "Autoflow — Negócio + APM",
  "description": "",
  "permissions": "PUBLIC_READ_WRITE",
  "pages": [
    {
      "name": "Negócio",
      "description": "",
      "widgets": [
        {
          "title": "Funnel de Ordens de Serviço",
          "visualization": { "id": "viz.bar" },
          "layout": { "column": 1, "row": 1, "width": 6, "height": 3 },
          "rawConfiguration": {
            "facet": { "showOtherSeries": false },
            "legend": { "enabled": true },
            "nrqlQueries": [
              {
                "accountIds": [__ACCOUNT_ID__],
                "query": "SELECT count(*) FROM AutoflowBizEvent WHERE eventName IN ('OrderCreated','BudgetApproved','OrderCancelled','PaymentApproved') FACET CASES (WHERE eventName='OrderCreated' AS '1. Criadas', WHERE eventName='BudgetApproved' AS '2. Budget aprovado', WHERE eventName='PaymentApproved' AS '3. Pagas', WHERE eventName='OrderCancelled' AS '4. Canceladas') SINCE 1 day ago"
              }
            ],
            "platformOptions": { "ignoreTimeRange": false }
          }
        },
        {
          "title": "Conversão pagamento (aprovado vs rejeitado)",
          "visualization": { "id": "viz.pie" },
          "layout": { "column": 7, "row": 1, "width": 3, "height": 3 },
          "rawConfiguration": {
            "facet": { "showOtherSeries": false },
            "legend": { "enabled": true },
            "nrqlQueries": [
              {
                "accountIds": [__ACCOUNT_ID__],
                "query": "SELECT count(*) FROM AutoflowBizEvent WHERE eventName IN ('PaymentApproved','PaymentRejected') FACET eventName SINCE 1 day ago"
              }
            ]
          }
        },
        {
          "title": "Valor R$ aprovado (acumulado)",
          "visualization": { "id": "viz.billboard" },
          "layout": { "column": 10, "row": 1, "width": 3, "height": 3 },
          "rawConfiguration": {
            "thresholds": [],
            "nrqlQueries": [
              {
                "accountIds": [__ACCOUNT_ID__],
                "query": "SELECT sum(totalCents)/100 AS 'R$ aprovado' FROM AutoflowBizEvent WHERE eventName='PaymentApproved' SINCE 1 day ago"
              }
            ]
          }
        },
        {
          "title": "Tempo médio da saga (RESERVED → CONSUMED)",
          "visualization": { "id": "viz.line" },
          "layout": { "column": 1, "row": 4, "width": 6, "height": 3 },
          "rawConfiguration": {
            "legend": { "enabled": true },
            "yAxisLeft": { "zero": true },
            "nrqlQueries": [
              {
                "accountIds": [__ACCOUNT_ID__],
                "query": "SELECT average(elapsedMs)/1000 AS 'Reserva (s)', average(totalElapsedMs)/1000 AS 'Saga completa (s)' FROM AutoflowBizEvent WHERE eventName IN ('SagaReserved','SagaConsumed') TIMESERIES SINCE 1 hour ago"
              }
            ]
          }
        },
        {
          "title": "Saga: sucessos vs falhas",
          "visualization": { "id": "viz.stacked-bar" },
          "layout": { "column": 7, "row": 4, "width": 6, "height": 3 },
          "rawConfiguration": {
            "facet": { "showOtherSeries": false },
            "legend": { "enabled": true },
            "nrqlQueries": [
              {
                "accountIds": [__ACCOUNT_ID__],
                "query": "SELECT count(*) FROM AutoflowBizEvent WHERE eventName IN ('SagaReserved','SagaConsumed','SagaReservationFailed') FACET eventName TIMESERIES 5 minutes SINCE 1 hour ago"
              }
            ]
          }
        },
        {
          "title": "Movimento de estoque (RESERVE + OUT)",
          "visualization": { "id": "viz.line" },
          "layout": { "column": 1, "row": 7, "width": 8, "height": 3 },
          "rawConfiguration": {
            "facet": { "showOtherSeries": false },
            "legend": { "enabled": true },
            "yAxisLeft": { "zero": true },
            "nrqlQueries": [
              {
                "accountIds": [__ACCOUNT_ID__],
                "query": "SELECT sum(quantity) FROM AutoflowBizEvent WHERE eventName IN ('StockReserved','StockConsumed') FACET eventName TIMESERIES 5 minutes SINCE 1 hour ago"
              }
            ]
          }
        },
        {
          "title": "Estoque insuficiente (eventos)",
          "visualization": { "id": "viz.billboard" },
          "layout": { "column": 9, "row": 7, "width": 4, "height": 3 },
          "rawConfiguration": {
            "thresholds": [
              { "alertSeverity": "WARNING", "value": 1 },
              { "alertSeverity": "CRITICAL", "value": 10 }
            ],
            "nrqlQueries": [
              {
                "accountIds": [__ACCOUNT_ID__],
                "query": "SELECT count(*) AS 'StockInsufficient', uniqueCount(partId) AS 'Peças distintas' FROM AutoflowBizEvent WHERE eventName='StockInsufficient' SINCE 1 day ago"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "APM",
      "description": "",
      "widgets": [
        {
          "title": "Throughput por serviço (rpm)",
          "visualization": { "id": "viz.line" },
          "layout": { "column": 1, "row": 1, "width": 6, "height": 3 },
          "rawConfiguration": {
            "facet": { "showOtherSeries": false },
            "legend": { "enabled": true },
            "nrqlQueries": [
              {
                "accountIds": [__ACCOUNT_ID__],
                "query": "SELECT rate(count(*), 1 minute) AS rpm FROM Transaction FACET appName TIMESERIES SINCE 1 hour ago"
              }
            ]
          }
        },
        {
          "title": "Latência p95 por serviço (ms)",
          "visualization": { "id": "viz.line" },
          "layout": { "column": 7, "row": 1, "width": 6, "height": 3 },
          "rawConfiguration": {
            "facet": { "showOtherSeries": false },
            "legend": { "enabled": true },
            "yAxisLeft": { "zero": true },
            "nrqlQueries": [
              {
                "accountIds": [__ACCOUNT_ID__],
                "query": "SELECT percentile(duration*1000, 95) FROM Transaction FACET appName TIMESERIES SINCE 1 hour ago"
              }
            ]
          }
        },
        {
          "title": "Erros por serviço (5xx + exceptions)",
          "visualization": { "id": "viz.stacked-bar" },
          "layout": { "column": 1, "row": 4, "width": 6, "height": 3 },
          "rawConfiguration": {
            "facet": { "showOtherSeries": false },
            "legend": { "enabled": true },
            "nrqlQueries": [
              {
                "accountIds": [__ACCOUNT_ID__],
                "query": "SELECT count(*) FROM TransactionError FACET appName TIMESERIES 5 minutes SINCE 1 hour ago"
              }
            ]
          }
        },
        {
          "title": "Apdex por serviço",
          "visualization": { "id": "viz.table" },
          "layout": { "column": 7, "row": 4, "width": 6, "height": 3 },
          "rawConfiguration": {
            "facet": { "showOtherSeries": false },
            "nrqlQueries": [
              {
                "accountIds": [__ACCOUNT_ID__],
                "query": "SELECT apdex(duration, t: 0.5) AS Apdex, average(duration*1000) AS 'Avg ms', count(*) AS Reqs FROM Transaction FACET appName SINCE 1 hour ago"
              }
            ]
          }
        },
        {
          "title": "Top 10 transações mais lentas",
          "visualization": { "id": "viz.table" },
          "layout": { "column": 1, "row": 7, "width": 12, "height": 3 },
          "rawConfiguration": {
            "facet": { "showOtherSeries": false },
            "nrqlQueries": [
              {
                "accountIds": [__ACCOUNT_ID__],
                "query": "SELECT average(duration*1000) AS 'Avg ms', percentile(duration*1000, 95) AS 'p95 ms', count(*) AS Reqs FROM Transaction FACET appName, name LIMIT 10 SINCE 1 hour ago"
              }
            ]
          }
        }
      ]
    }
  ]
}
